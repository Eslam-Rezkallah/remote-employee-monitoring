# ════════════════════════════════════════════════════════════
# REM Backend — Environment Configuration
# Copy to .env.dev (development) or .env.prod (production)
# ════════════════════════════════════════════════════════════

# ─── Application ────────────────────────────────────────────
MOOD=DEV
APP_NAME=REM
PORT=3000

# ─── Database ───────────────────────────────────────────────
DB_URI=mongodb://127.0.0.1:27017/REM

# ─── Redis (required from Phase 2 onward) ───────────────────
REDIS_URL=redis://localhost:6379

# ─── Security ───────────────────────────────────────────────
# IMPORTANT: each secret must be at least 32 chars, ideally 64.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SALT=12
USER_ACCESS_TOKEN=REPLACE_WITH_64_CHAR_HEX
USER_REFRESH_TOKEN=REPLACE_WITH_DIFFERENT_64_CHAR_HEX
ADMIN_ACCESS_TOKEN=REPLACE_WITH_64_CHAR_HEX
ADMIN_REFRESH_TOKEN=REPLACE_WITH_DIFFERENT_64_CHAR_HEX
ACCESS_TOKEN_EXPIRATION=15m
REFRESH_TOKEN_EXPIRATION=7d

# ─── Email (SMTP / Gmail App Password) ──────────────────────
EMAIL=your-app@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# ─── Cloudinary ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── OAuth ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ─── AI Services (optional) ─────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Frontend ───────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000